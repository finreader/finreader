<div class="min-h-screen flex flex-col items-center justify-center px-4">
  <div class="text-center mb-12">
    <h1 class="font-serif text-5xl font-bold text-stone-900 mb-3">Finreader</h1>
    <p class="text-stone-500 text-lg">Read SEC filings the way they were meant to be read.</p>
  </div>

  <div class="w-full max-w-md relative"
       data-controller="search"
       data-action="keydown->search#handleKeydown">
    <input type="text"
           placeholder="Search by ticker symbol (e.g. AAPL)"
           autocomplete="off"
           autofocus
           class="w-full px-5 py-4 text-lg rounded-xl border border-stone-300 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-stone-400 focus:border-transparent placeholder:text-stone-400"
           data-search-target="input"
           data-action="input->search#search">

    <div class="hidden absolute z-50 w-full mt-2 bg-white border border-stone-200 rounded-xl shadow-lg overflow-hidden"
         data-search-target="panel">
      <div data-search-target="results"></div>
    </div>
  </div>
</div>
