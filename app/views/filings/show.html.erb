<% content_for(:title) { "#{@company.ticker} #{@filing.form_type} #{@filing.period_of_report.year} — Finreader" } %>

<div class="min-h-screen" data-controller="toc">
  <%# Top bar %>
  <header class="sticky top-0 z-10 bg-stone-50/95 backdrop-blur border-b border-stone-200 px-4 py-3">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <div class="flex items-center gap-4">
        <%= link_to company_path(@company.ticker), class: "text-sm text-stone-500 hover:text-stone-700" do %>
          ← <%= @company.ticker %>
        <% end %>
        <span class="text-stone-300">|</span>
        <h1 class="font-sans font-semibold text-stone-900">
          <%= @filing.form_type %> — <%= @filing.period_of_report.year %>
        </h1>
      </div>
      <span class="text-sm text-stone-400">
        Filed <%= @filing.filing_date.strftime("%B %d, %Y") %>
      </span>
    </div>
  </header>

  <div class="max-w-7xl mx-auto flex">
    <%# Table of contents sidebar %>
    <aside class="hidden lg:block w-64 shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto py-8 pl-4 pr-6">
      <nav>
        <h2 class="font-sans text-xs font-semibold text-stone-400 uppercase tracking-wider mb-4">Contents</h2>
        <ul class="space-y-1">
          <% @sections.each do |section| %>
            <li>
              <a href="#<%= section["anchor"] %>"
                 class="toc-link block text-sm py-1 pl-3 border-l-2 border-stone-200 text-stone-500 hover:text-stone-800 hover:border-stone-400"
                 data-toc-target="link"
                 data-section="<%= section["anchor"] %>">
                <%= section["title"] %>
              </a>
            </li>
          <% end %>
        </ul>
      </nav>
    </aside>

    <%# Main reading pane %>
    <main class="flex-1 min-w-0 max-w-3xl mx-auto px-4 py-8">
      <% @sections.each do |section| %>
        <article id="<%= section["anchor"] %>"
                 class="mb-12 <%= "section-collapsed" if section["collapsible"] %>"
                 data-controller="collapse"
                 data-toc-target="section"
                 data-section="<%= section["anchor"] %>">

          <h2 class="font-sans text-xl font-semibold text-stone-900 mb-4 flex items-center gap-3">
            <%= section["title"] %>
            <% if section["collapsible"] %>
              <button class="section-toggle text-xs font-normal text-stone-400 hover:text-stone-600 border border-stone-300 rounded px-2 py-0.5"
                      data-action="click->collapse#toggle"
                      data-collapse-target="button">
                Show
              </button>
            <% end %>
          </h2>

          <div class="section-content filing-reader">
            <%= raw section["content_html"] %>
          </div>
        </article>
      <% end %>
    </main>
  </div>
</div>
